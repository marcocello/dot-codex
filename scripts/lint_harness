#!/usr/bin/env python3
from __future__ import annotations

import argparse
import re
import sys
from collections import defaultdict
from dataclasses import dataclass
from pathlib import Path

import yaml


TEXT_SUFFIXES = {".md", ".yaml", ".yml", ".toml", ".json", ".py", ".txt"}
REFERENCE_PREFIXES = ("coding-", "prospecting-")
SKIP_DIRS = {".git", ".venv", "__pycache__", "node_modules"}
NON_SKILL_TERMS = {
    "coding-agent",
    "coding-agents",
    "coding-oriented",
}


SECRET_PATTERNS = [
    ("Context7 API key", re.compile(r"\bctx7sk-[A-Za-z0-9._-]+\b")),
    ("OpenAI API key", re.compile(r"\bsk-[A-Za-z0-9][A-Za-z0-9_-]{20,}\b")),
    ("GitHub token", re.compile(r"\bgh[pousr]_[A-Za-z0-9_]{20,}\b")),
    ("AWS access key", re.compile(r"\bAKIA[0-9A-Z]{16}\b")),
    (
        "inline secret assignment",
        re.compile(
            r"(?i)(api[_-]?key|token|secret|password)\s*=\s*"
            r"[\"'](?!\$\{|<|your-|changeme|placeholder|redacted)([^\"']{12,})[\"']"
        ),
    ),
]


@dataclass(frozen=True)
class Finding:
    code: str
    path: Path
    message: str
    line: int | None = None

    def format(self, root: Path) -> str:
        rel = self.path.relative_to(root) if self.path.is_relative_to(root) else self.path
        location = f"{rel}:{self.line}" if self.line else str(rel)
        return f"{self.code}: {location}: {self.message}"


@dataclass(frozen=True)
class Skill:
    name: str
    description: str
    path: Path


def parse_frontmatter(text: str) -> dict[str, str]:
    if not text.startswith("---\n"):
        return {}
    end = text.find("\n---", 4)
    if end == -1:
        return {}

    frontmatter = yaml.safe_load(text[4:end])
    if not isinstance(frontmatter, dict):
        return {}
    return {str(key): str(value) for key, value in frontmatter.items() if value is not None}


def skill_files(root: Path) -> list[Path]:
    paths = list((root / "skills").glob("**/SKILL.md"))
    paths.extend((root / "plugins" / "cache").glob("**/SKILL.md"))
    return sorted(path for path in paths if path.is_file())


def load_skills(root: Path) -> tuple[list[Skill], list[Finding]]:
    skills: list[Skill] = []
    findings: list[Finding] = []

    for path in skill_files(root):
        text = path.read_text(encoding="utf-8")
        frontmatter = parse_frontmatter(text)
        name = frontmatter.get("name", "")
        description = frontmatter.get("description", "")

        if not name:
            findings.append(Finding("skill-frontmatter", path, "missing skill name"))
            continue
        if not description:
            findings.append(Finding("skill-frontmatter", path, "missing skill description"))

        skills.append(Skill(name=name, description=description, path=path))

    return skills, findings


def operational_text_files(root: Path, include_local_config: bool) -> list[Path]:
    roots = [
        root / "AGENTS.md",
        root / "README.md",
        root / "config.template.toml",
    ]
    if include_local_config:
        roots.append(root / "config.toml")

    files = [path for path in roots if path.is_file()]
    for base in [root / "skills"]:
        if not base.exists():
            continue
        for path in base.rglob("*"):
            if path.is_file() and path.suffix in TEXT_SUFFIXES:
                files.append(path)
    return sorted(set(files))


def text_line(text: str, offset: int) -> int:
    return text.count("\n", 0, offset) + 1


def check_stale_references(root: Path, skills: list[Skill], files: list[Path]) -> list[Finding]:
    names = {skill.name for skill in skills}
    findings: list[Finding] = []
    reference_pattern = re.compile(r"(?<![A-Za-z0-9_-])((?:coding|prospecting)-[a-z0-9-]+)")

    for path in files:
        text = path.read_text(encoding="utf-8")
        for match in reference_pattern.finditer(text):
            token = match.group(1)
            if token in names:
                continue
            if token in NON_SKILL_TERMS:
                continue
            if not token.startswith(REFERENCE_PREFIXES):
                continue
            findings.append(
                Finding(
                    "stale-skill-reference",
                    path,
                    f"references deleted or unknown skill `{token}`",
                    text_line(text, match.start()),
                )
            )

    return findings


def check_duplicate_descriptions(root: Path, skills: list[Skill]) -> list[Finding]:
    by_description: dict[str, list[Skill]] = defaultdict(list)
    for skill in skills:
        if skill.description:
            by_description[skill.description].append(skill)

    findings: list[Finding] = []
    for description, duplicates in by_description.items():
        if len(duplicates) < 2:
            continue
        names = ", ".join(sorted(skill.name for skill in duplicates))
        for skill in duplicates:
            findings.append(
                Finding(
                    "duplicate-skill-description",
                    skill.path,
                    f"description duplicated by: {names}",
                )
            )
    return findings


def config_files(root: Path, include_local_config: bool) -> list[Path]:
    files = [root / "config.template.toml"]
    if include_local_config:
        files.append(root / "config.toml")
    return [path for path in files if path.is_file()]


def check_inline_secrets(root: Path, include_local_config: bool) -> list[Finding]:
    findings: list[Finding] = []
    for path in config_files(root, include_local_config):
        text = path.read_text(encoding="utf-8")
        for name, pattern in SECRET_PATTERNS:
            for match in pattern.finditer(text):
                findings.append(
                    Finding(
                        "inline-secret",
                        path,
                        f"possible {name}; move secrets out of checked config text",
                        text_line(text, match.start()),
                    )
                )
    return findings


def read_yaml_text(path: Path) -> str:
    return path.read_text(encoding="utf-8") if path.is_file() else ""


def agent_references(agent_path: Path) -> set[str]:
    text = read_yaml_text(agent_path)
    dollar_ref = re.compile(r"\$((?:coding|prospecting)-[a-z0-9-]+)")
    return set(dollar_ref.findall(text))


def check_missing_agent_self_reference(skills: list[Skill]) -> list[Finding]:
    findings: list[Finding] = []

    for skill in skills:
        agent_path = skill.path.parent / "agents" / "openai.yaml"
        if not agent_path.exists() or not skill.name.startswith(REFERENCE_PREFIXES):
            continue
        if not agent_references(agent_path):
            findings.append(
                Finding(
                    "agent-missing-skill-reference",
                    agent_path,
                    f"agent prompt should mention `${skill.name}`",
                )
            )

    return findings


def check_agent_skill_mismatches(skills: list[Skill]) -> list[Finding]:
    findings: list[Finding] = []

    for skill in skills:
        agent_path = skill.path.parent / "agents" / "openai.yaml"
        if not agent_path.exists():
            continue
        references = agent_references(agent_path)
        if references and skill.name not in references:
            findings.append(
                Finding(
                    "agent-skill-mismatch",
                    agent_path,
                    f"agent prompt references {sorted(references)} but skill is `{skill.name}`",
                )
            )

    return findings


def check_agent_deleted_references(skills: list[Skill]) -> list[Finding]:
    names = {skill.name for skill in skills}
    findings: list[Finding] = []

    for skill in skills:
        agent_path = skill.path.parent / "agents" / "openai.yaml"
        if not agent_path.exists():
            continue
        for reference in agent_references(agent_path):
            if reference in names:
                continue
            findings.append(
                Finding(
                    "agent-deleted-skill-reference",
                    agent_path,
                    f"agent prompt references deleted or unknown skill `{reference}`",
                )
            )

    return findings


def check_agent_description_alignment(skills: list[Skill]) -> list[Finding]:
    findings: list[Finding] = []

    for skill in skills:
        agent_path = skill.path.parent / "agents" / "openai.yaml"
        if not agent_path.exists():
            continue
        text = read_yaml_text(agent_path)
        if "failing check" in skill.description.lower() and "failing check" not in text.lower():
            findings.append(
                Finding(
                    "agent-description-mismatch",
                    agent_path,
                    "skill description mentions `failing check` but agent metadata does not",
                )
            )

    return findings


def main() -> int:
    parser = argparse.ArgumentParser(description="Lint local Codex harness configuration.")
    parser.add_argument("--root", type=Path, default=Path.cwd())
    parser.add_argument(
        "--include-local-config",
        action="store_true",
        help="also scan user-local config.toml for inline secrets",
    )
    args = parser.parse_args()

    root = args.root.resolve()
    skills, findings = load_skills(root)
    files = operational_text_files(root, args.include_local_config)

    findings.extend(check_stale_references(root, skills, files))
    findings.extend(check_duplicate_descriptions(root, skills))
    findings.extend(check_inline_secrets(root, args.include_local_config))
    findings.extend(check_missing_agent_self_reference(skills))
    findings.extend(check_agent_skill_mismatches(skills))
    findings.extend(check_agent_deleted_references(skills))
    findings.extend(check_agent_description_alignment(skills))

    if findings:
        for finding in sorted(findings, key=lambda item: item.format(root)):
            print(finding.format(root), file=sys.stderr)
        return 1

    print("lint_harness: ok")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
