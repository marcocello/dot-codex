#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path


def timestamp() -> str:
    return datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")


def copy_files(paths: list[Path], target_dir: Path) -> list[str]:
    target_dir.mkdir(parents=True, exist_ok=True)
    copied: list[str] = []
    for source in paths:
        if not source.exists():
            continue
        destination = target_dir / source.name
        shutil.copy2(source, destination)
        copied.append(str(destination))
    return copied


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Run a proof command and write FEATURE_DIR/proof/runs evidence."
    )
    parser.add_argument("--feature-dir", required=True, type=Path)
    parser.add_argument("--notes", default="", help="Short note for notes.md")
    parser.add_argument("--log", action="append", default=[], type=Path)
    parser.add_argument("--screenshot", action="append", default=[], type=Path)
    parser.add_argument("--provider-readback", type=Path)
    parser.add_argument("command", nargs=argparse.REMAINDER)
    args = parser.parse_args()
    if not args.command or args.command[0] != "--":
        parser.error("pass the proof command after --")
    args.command = args.command[1:]
    if not args.command:
        parser.error("missing proof command")
    return args


def write_bundle(args: argparse.Namespace, result: subprocess.CompletedProcess[str]) -> Path:
    run_dir = args.feature_dir / "proof" / "runs" / timestamp()
    run_dir.mkdir(parents=True, exist_ok=False)

    command_text = " ".join(args.command)
    (run_dir / "command.txt").write_text(command_text + "\n", encoding="utf-8")
    (run_dir / "stdout.txt").write_text(result.stdout, encoding="utf-8")
    (run_dir / "stderr.txt").write_text(result.stderr, encoding="utf-8")

    copied_logs = copy_files(args.log, run_dir / "logs")
    copied_screenshots = copy_files(args.screenshot, run_dir / "screenshots")
    provider_readback = None
    if args.provider_readback and args.provider_readback.exists():
        destination = run_dir / "provider-readback.json"
        shutil.copy2(args.provider_readback, destination)
        provider_readback = str(destination)

    status = "PASS" if result.returncode == 0 else "FAIL"
    metadata = {
        "status": status,
        "returncode": result.returncode,
        "command": args.command,
        "created_at": datetime.now(timezone.utc).isoformat(),
        "stdout": str(run_dir / "stdout.txt"),
        "stderr": str(run_dir / "stderr.txt"),
        "logs": copied_logs,
        "screenshots": copied_screenshots,
        "provider_readback": provider_readback,
    }
    (run_dir / "result.json").write_text(
        json.dumps(metadata, indent=2, sort_keys=True) + "\n",
        encoding="utf-8",
    )

    note = args.notes or f"Proof command exited with {status}."
    (run_dir / "notes.md").write_text(note.rstrip() + "\n", encoding="utf-8")
    return run_dir


def main() -> int:
    args = parse_args()
    result = subprocess.run(args.command, capture_output=True, text=True, check=False)
    run_dir = write_bundle(args, result)
    print(f"proof_run_capture: {run_dir}")
    return result.returncode


if __name__ == "__main__":
    sys.exit(main())
