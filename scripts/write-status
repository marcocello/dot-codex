#!/usr/bin/env python3
import argparse
import json
import subprocess
from pathlib import Path


def parse_bool(value: str) -> bool:
    lowered = value.strip().lower()
    if lowered in {"1", "true", "yes", "y"}:
        return True
    if lowered in {"0", "false", "no", "n"}:
        return False
    raise argparse.ArgumentTypeError(f"invalid boolean value: {value}")


def head_sha() -> str:
    proc = subprocess.run(
        ["git", "rev-parse", "HEAD"],
        text=True,
        capture_output=True,
    )
    if proc.returncode != 0:
        return "no-git"
    return proc.stdout.strip()


def main() -> int:
    parser = argparse.ArgumentParser(prog="scripts/write-status")
    parser.add_argument("--feature", default="")
    parser.add_argument("--phase", default="")
    parser.add_argument("--gate-passed", type=parse_bool, default=False)
    parser.add_argument("--acceptance-passed", type=parse_bool, default=False)
    parser.add_argument("--summary", default="")
    args = parser.parse_args()

    payload = {
        "feature_dir": args.feature,
        "phase": args.phase,
        "head_sha": head_sha(),
        "gate": {"cmd": "./scripts/gate", "passed": args.gate_passed},
        "acceptance": {
            "cmd": f"./scripts/acceptance --feature {args.feature}",
            "passed": args.acceptance_passed,
        },
        "summary": [args.summary] if args.summary else [],
    }

    press_dir = Path(".press")
    press_dir.mkdir(parents=True, exist_ok=True)
    (press_dir / "status.json").write_text(json.dumps(payload, indent=2), encoding="utf-8")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
