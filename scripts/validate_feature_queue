#!/usr/bin/env python3
from __future__ import annotations

import argparse
import hashlib
import json
import os
import sys
from pathlib import Path
from typing import Any


PASS_STATUSES = {"PASS", "pass", "passed", True}
EVIDENCE_SCHEMA_VERSION = 3
RECEIPT_SCHEMA_VERSION = 1
SERIOUS_EVIDENCE_FILES = ["command.txt", "notes.md", "run-metadata.json", "oracle-scope.md"]
EXECUTABLE_STATUSES = {"ready", "in_progress", "repairing", "done"}
ORACLE_HEADINGS = ["Proves:", "Does not prove:", "False-green risks:", "Evidence strength:"]
PLACEHOLDERS = {"", "-", "none", "n/a", "na", "todo", "tbd", "<placeholder>"}


def load_json(path: Path) -> dict[str, Any]:
    with path.open(encoding="utf-8") as handle:
        data = json.load(handle)
    if not isinstance(data, dict):
        raise ValueError("status file must contain a JSON object")
    return data


def is_pass(value: Any) -> bool:
    return value in PASS_STATUSES


def sha256_path(path: Path) -> str:
    digest = hashlib.sha256()
    if path.is_symlink():
        digest.update(b"symlink\0")
        digest.update(os.readlink(path).encode("utf-8"))
        return digest.hexdigest()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()


def oracle_sections(text: str) -> dict[str, list[str]]:
    sections: dict[str, list[str]] = {heading: [] for heading in ORACLE_HEADINGS}
    current: str | None = None
    for raw_line in text.splitlines():
        line = raw_line.strip()
        matched = next((heading for heading in ORACLE_HEADINGS if line == heading), None)
        if matched:
            current = matched
            continue
        if current:
            sections[current].append(line)
    return sections


def has_real_section_content(lines: list[str]) -> bool:
    content = " ".join(line.strip("- ").strip() for line in lines).strip()
    if content.lower() in PLACEHOLDERS:
        return False
    return bool(content) and "<" not in content and ">" not in content


def validate_oracle_scope(evidence_path: Path, feature_id: str) -> list[str]:
    path = evidence_path / "oracle-scope.md"
    if not path.is_file():
        return []
    text = path.read_text(encoding="utf-8")
    errors: list[str] = []
    sections = oracle_sections(text)
    for heading in ORACLE_HEADINGS:
        if heading not in text:
            errors.append(f"{feature_id}: latest_evidence oracle-scope.md missing {heading}")
            continue
        if not has_real_section_content(sections[heading]):
            errors.append(
                f"{feature_id}: latest_evidence oracle-scope.md {heading} has no concrete content"
            )
    return errors


def validate_serious_evidence(evidence_path: Path, feature_id: str) -> list[str]:
    errors: list[str] = []
    for name in SERIOUS_EVIDENCE_FILES:
        if not (evidence_path / name).is_file():
            errors.append(f"{feature_id}: latest_evidence missing {name}")

    metadata_path = evidence_path / "run-metadata.json"
    if not metadata_path.is_file():
        return errors

    try:
        metadata = load_json(metadata_path)
    except (OSError, ValueError, json.JSONDecodeError) as exc:
        errors.append(f"{feature_id}: latest_evidence run-metadata.json invalid: {exc}")
        return errors

    if not metadata.get("behavior_boundary"):
        errors.append(f"{feature_id}: latest_evidence run-metadata.json missing behavior_boundary")
    if not metadata.get("oracle_scope"):
        errors.append(f"{feature_id}: latest_evidence run-metadata.json missing oracle_scope")
    if metadata.get("schema_version") != EVIDENCE_SCHEMA_VERSION:
        errors.append(
            f"{feature_id}: latest_evidence run-metadata.json schema_version "
            f"must be {EVIDENCE_SCHEMA_VERSION}"
        )

    attempt = metadata.get("attempt", 1)
    if not isinstance(attempt, int) or attempt < 1:
        errors.append(f"{feature_id}: latest_evidence run-metadata.json attempt must be a positive integer")
        return errors
    errors.extend(validate_attempt_log(evidence_path, feature_id, metadata, attempt))
    errors.extend(validate_observation_requirement(evidence_path, feature_id, metadata, attempt))
    errors.extend(validate_oracle_scope(evidence_path, feature_id))
    return errors


def validate_attempt_log(
    evidence_path: Path,
    feature_id: str,
    metadata: dict[str, Any],
    attempt: int,
) -> list[str]:
    if attempt == 1 and not metadata.get("failure_class") and not metadata.get("repair_action"):
        return []

    attempts_path = evidence_path / "attempts.json"
    if not attempts_path.is_file():
        return [f"{feature_id}: latest_evidence missing attempts.json for repeated repair"]
    try:
        attempts = json.loads(attempts_path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        return [f"{feature_id}: latest_evidence attempts.json invalid: {exc}"]
    if not isinstance(attempts, list) or not all(isinstance(item, dict) for item in attempts):
        return [f"{feature_id}: latest_evidence attempts.json must contain attempt objects"]
    if not any(item.get("attempt") == attempt for item in attempts):
        return [f"{feature_id}: latest_evidence attempts.json missing attempt {attempt}"]
    if attempt > 1 and not metadata.get("failure_class"):
        return [f"{feature_id}: latest_evidence missing failure_class for repeated attempt"]
    if attempt > 1 and not metadata.get("repair_action"):
        return [f"{feature_id}: latest_evidence missing repair_action for repeated attempt"]
    return []


def load_evidence_json(path: Path, feature_id: str) -> tuple[dict[str, Any] | None, list[str]]:
    try:
        return load_json(path), []
    except (OSError, ValueError, json.JSONDecodeError) as exc:
        return None, [f"{feature_id}: latest_evidence {path.name} invalid: {exc}"]


def evidence_directory(root: Path, item: dict[str, Any]) -> tuple[Path | None, list[str]]:
    feature_id = item.get("id", "<unknown>")
    evidence = item.get("completion", {}).get("latest_evidence")
    feature_dir = item.get("feature_dir")
    if not isinstance(evidence, str) or not evidence:
        return None, [f"{feature_id}: completion.latest_evidence is required"]
    path = Path(evidence)
    expected_prefix = f"{feature_dir}/proof/runs/" if isinstance(feature_dir, str) else ""
    if path.is_absolute() or not evidence.startswith(expected_prefix):
        return None, [
            f"{feature_id}: completion.latest_evidence must point to one feature proof run directory"
        ]
    resolved = (root / path).resolve()
    try:
        resolved.relative_to(root.resolve())
    except ValueError:
        return None, [f"{feature_id}: completion.latest_evidence escapes the repository root"]
    if not resolved.is_dir():
        return None, [f"{feature_id}: completion.latest_evidence directory does not exist"]
    return resolved, []


def validate_identity_file(
    root: Path,
    record: Any,
    expected_path: Path | None,
    label: str,
) -> list[str]:
    if not isinstance(record, dict):
        return [f"{label} identity is missing"]
    recorded_path = record.get("path")
    recorded_hash = record.get("sha256")
    if not isinstance(recorded_path, str) or not isinstance(recorded_hash, str):
        return [f"{label} identity is incomplete"]
    current_path = root / recorded_path
    if expected_path is not None:
        expected_relative = expected_path.resolve().relative_to(root.resolve()).as_posix()
        if recorded_path != expected_relative:
            return [f"{label} identity path does not match queue contract"]
    if not current_path.is_file() and not current_path.is_symlink():
        return [f"{label} identity path is missing"]
    if sha256_path(current_path) != recorded_hash:
        return [f"{label} hash does not match current content"]
    return []


def validate_contract_snapshot(
    evidence_path: Path,
    source: dict[str, Any],
    name: str,
    label: str,
) -> list[str]:
    snapshot = evidence_path / "contracts" / name
    record = source.get(label)
    if not snapshot.is_file():
        return [f"{label} contract snapshot is missing"]
    if not isinstance(record, dict) or snapshot.name != name:
        return [f"{label} contract identity is missing"]
    if sha256_path(snapshot) != record.get("sha256"):
        return [f"{label} contract snapshot hash is invalid"]
    return []


def validate_declared_sources(root: Path, records: Any) -> list[str]:
    if not isinstance(records, list) or not records:
        return ["declared source identities are missing"]
    errors: list[str] = []
    seen: set[str] = set()
    for record in records:
        if not isinstance(record, dict):
            errors.append("declared source identity is invalid")
            continue
        path_value = record.get("path")
        recorded_hash = record.get("sha256")
        if not isinstance(path_value, str) or not isinstance(recorded_hash, str):
            errors.append("declared source identity is incomplete")
            continue
        if path_value in seen:
            errors.append(f"declared source identity is duplicated: {path_value}")
            continue
        seen.add(path_value)
        relative = Path(path_value)
        if relative.is_absolute():
            errors.append(f"declared source path must be repository-relative: {path_value}")
            continue
        current_path = (root / relative).resolve()
        try:
            current_path.relative_to(root.resolve())
        except ValueError:
            errors.append(f"declared source path escapes repository root: {path_value}")
            continue
        lexical_path = root / relative
        if not lexical_path.is_file() and not lexical_path.is_symlink():
            errors.append(f"declared source path is missing: {path_value}")
            continue
        if sha256_path(lexical_path) != recorded_hash:
            errors.append(f"declared source hash does not match current content: {path_value}")
    return errors


def validate_source_identity(
    root: Path,
    item: dict[str, Any],
    evidence_path: Path,
    metadata: dict[str, Any],
) -> list[str]:
    feature_id = item.get("id", "<unknown>")
    source = metadata.get("source")
    if not isinstance(source, dict):
        return [f"{feature_id}: latest_evidence source identity is missing"]
    feature_dir = item.get("feature_dir")
    proof = item.get("proof")
    if not isinstance(feature_dir, str) or not isinstance(proof, str):
        return [f"{feature_id}: queue contract paths are incomplete"]
    feature_path = root / feature_dir / "FEATURE.md"
    proof_path = root / proof
    errors = [
        f"{feature_id}: {message}"
        for message in validate_identity_file(root, source.get("feature"), feature_path, "feature contract")
    ]
    errors.extend(
        f"{feature_id}: {message}"
        for message in validate_identity_file(root, source.get("proof"), proof_path, "proof contract")
    )
    errors.extend(
        f"{feature_id}: {message}"
        for message in validate_identity_file(root, source.get("runner"), None, "proof runner")
    )
    errors.extend(
        f"{feature_id}: {message}"
        for message in validate_contract_snapshot(evidence_path, source, "FEATURE.md", "feature")
    )
    errors.extend(
        f"{feature_id}: {message}"
        for message in validate_contract_snapshot(evidence_path, source, "PROOF.md", "proof")
    )
    errors.extend(
        f"{feature_id}: {message}"
        for message in validate_declared_sources(root, source.get("inputs"))
    )
    return errors


def receipt_evidence_path(root: Path, value: Any) -> Path | None:
    if not isinstance(value, str) or not value:
        return None
    path = Path(value)
    return path.resolve() if path.is_absolute() else (root / path).resolve()


def validate_completion_receipts(
    root: Path,
    feature_id: str,
    evidence_path: Path,
) -> list[str]:
    errors: list[str] = []
    gate_path = evidence_path / "gate.json"
    evaluation_path = evidence_path / "evaluation.json"
    if not gate_path.is_file():
        errors.append(f"{feature_id}: latest_evidence missing gate.json")
    if not evaluation_path.is_file():
        errors.append(f"{feature_id}: latest_evidence missing evaluation.json")
    if errors:
        return errors
    gate, gate_errors = load_evidence_json(gate_path, feature_id)
    evaluation, evaluation_errors = load_evidence_json(evaluation_path, feature_id)
    errors.extend(gate_errors + evaluation_errors)
    if gate is None or evaluation is None:
        return errors
    if gate.get("schema_version") != RECEIPT_SCHEMA_VERSION or not is_pass(gate.get("status")):
        errors.append(f"{feature_id}: gate.json must contain a schema-valid PASS")
    if gate.get("returncode") != 0 or not isinstance(gate.get("command"), list) or not gate.get("command"):
        errors.append(f"{feature_id}: gate.json command evidence is incomplete")
    if evaluation.get("schema_version") != RECEIPT_SCHEMA_VERSION or evaluation.get("result") != "PASS":
        errors.append(f"{feature_id}: evaluation.json must contain a schema-valid PASS")
    reasoning = (
        evaluation.get("summary"),
        evaluation.get("findings"),
        evaluation.get("required_next_action"),
    )
    if (
        not isinstance(reasoning[0], str)
        or not reasoning[0].strip()
        or not isinstance(reasoning[1], list)
        or not isinstance(reasoning[2], str)
        or not reasoning[2].strip()
    ):
        errors.append(f"{feature_id}: evaluation.json missing evaluator reasoning")
    if evaluation.get("central_behavior_gaps") != []:
        errors.append(f"{feature_id}: evaluation.json contains central behavior gaps")
    if evaluation.get("broken_implementation_can_pass") is not False:
        errors.append(f"{feature_id}: evaluation.json allows a broken implementation to pass")
    if evaluation.get("contract_evidence_revision_match") != "PASS":
        errors.append(f"{feature_id}: evaluation.json contract/evidence revision does not match")
    if evaluation.get("primary_proof") != "PASS" or evaluation.get("gate") != "PASS":
        errors.append(f"{feature_id}: evaluation.json proof and gate must both be PASS")
    if receipt_evidence_path(root, evaluation.get("evidence_bundle")) != evidence_path.resolve():
        errors.append(f"{feature_id}: evaluation.json references a different evidence bundle")
    return errors


def observation_required(metadata: dict[str, Any], attempt: int) -> bool:
    return attempt > 1 or bool(metadata.get("failure_class")) or bool(metadata.get("repair_action"))


def validate_observation_requirement(
    evidence_path: Path,
    feature_id: str,
    metadata: dict[str, Any],
    attempt: int,
) -> list[str]:
    if observation_required(metadata, attempt) and not (evidence_path / "agent-observation.md").is_file():
        return [
            f"{feature_id}: latest_evidence missing agent-observation.md "
            "for repeated or repaired proof attempt"
        ]
    return []


def validate_evidence(root: Path, item: dict[str, Any]) -> list[str]:
    errors: list[str] = []
    completion = item.get("completion")
    feature_id = item.get("id", "<unknown>")
    if not isinstance(completion, dict):
        return [f"{feature_id}: done item missing completion object"]

    evidence_path, path_errors = evidence_directory(root, item)
    errors.extend(path_errors)
    if evidence_path is None:
        return errors
    result_path = evidence_path / "result.json"
    if not result_path.is_file():
        errors.append(f"{feature_id}: latest_evidence missing result.json")
        return errors

    try:
        result = load_json(result_path)
    except (OSError, ValueError, json.JSONDecodeError) as exc:
        errors.append(f"{feature_id}: latest_evidence result.json invalid: {exc}")
        return errors

    if not is_pass(result.get("status")):
        errors.append(f"{feature_id}: latest_evidence result status must be PASS")
    if result.get("schema_version") != EVIDENCE_SCHEMA_VERSION:
        errors.append(
            f"{feature_id}: latest_evidence result.json schema_version "
            f"must be {EVIDENCE_SCHEMA_VERSION}"
        )
    errors.extend(validate_serious_evidence(evidence_path, feature_id))
    metadata_path = evidence_path / "run-metadata.json"
    if metadata_path.is_file():
        metadata, metadata_errors = load_evidence_json(metadata_path, feature_id)
        errors.extend(metadata_errors)
        if metadata is not None:
            errors.extend(validate_source_identity(root, item, evidence_path, metadata))
    errors.extend(validate_completion_receipts(root, feature_id, evidence_path))
    return errors


def validate_proof_capture(root: Path, item: dict[str, Any]) -> list[str]:
    status = item.get("status")
    if status not in EXECUTABLE_STATUSES:
        return []

    feature_id = item.get("id", "<unknown>")
    proof = item.get("proof")
    if not isinstance(proof, str) or not proof:
        return [f"{feature_id}: executable item missing proof path"]

    proof_path = root / proof
    if not proof_path.is_file():
        return [f"{feature_id}: proof path missing: {proof}"]

    text = proof_path.read_text(encoding="utf-8")
    if "proof_run_capture" not in text:
        return [f"{feature_id}: PROOF.md primary proof must use scripts/proof_run_capture"]
    if "--source-path" not in text:
        return [f"{feature_id}: PROOF.md primary proof must declare at least one --source-path"]
    return []


def validate_queue(root: Path, status_path: Path, feature_id: str | None) -> list[str]:
    data = load_json(status_path)
    features = data.get("features")
    if not isinstance(features, list):
        return ["status file must contain a features array"]

    if feature_id is not None:
        selected = [
            item
            for item in features
            if isinstance(item, dict) and item.get("id") == feature_id
        ]
        if not selected:
            return [f"unknown feature id: {feature_id}"]
        features = selected

    errors: list[str] = []
    for item in features:
        if not isinstance(item, dict):
            errors.append("feature entries must be objects")
            continue
        errors.extend(validate_proof_capture(root, item))
        if item.get("status") == "done":
            errors.extend(validate_evidence(root, item))
    return errors


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Validate docs/features/status.json done items.")
    parser.add_argument("--root", type=Path, default=Path.cwd())
    parser.add_argument("--status", type=Path, default=Path("docs/features/status.json"))
    mode = parser.add_mutually_exclusive_group(required=True)
    mode.add_argument("--feature", help="Validate one feature id and ignore unrelated queue items.")
    mode.add_argument("--all", action="store_true", dest="all_features", help="Validate every queue item.")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    status_path = args.status if args.status.is_absolute() else args.root / args.status
    if not status_path.exists():
        print("validate_feature_queue: no status file")
        return 0
    errors = validate_queue(args.root, status_path, args.feature)
    if errors:
        for error in errors:
            print(f"validate_feature_queue: {error}", file=sys.stderr)
        return 1
    print("validate_feature_queue: ok")
    return 0


if __name__ == "__main__":
    sys.exit(main())
