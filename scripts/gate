#!/usr/bin/env bash
set -euo pipefail

ROOT="$(pwd)"
ART_DIR="$ROOT/artifacts"
mkdir -p "$ART_DIR"

HEAD_SHA="$(git rev-parse HEAD 2>/dev/null || echo "no-git")"

fail() {
  local msg="$1"
  echo "GATE: FAIL: $msg" >&2
  python3 - <<PY
import json, os
p = {"head_sha": "$HEAD_SHA", "passed": False, "error": "$msg"}
os.makedirs("$ART_DIR", exist_ok=True)
with open("$ART_DIR/gate.json", "w", encoding="utf-8") as f:
  json.dump(p, f, indent=2)
PY
  exit 1
}

ok() {
  echo "GATE: PASS"
  python3 - <<PY
import json, os
p = {"head_sha": "$HEAD_SHA", "passed": True}
os.makedirs("$ART_DIR", exist_ok=True)
with open("$ART_DIR/gate.json", "w", encoding="utf-8") as f:
  json.dump(p, f, indent=2)
PY
}

echo "== gate: start =="
echo "repo=$ROOT"
echo "head_sha=$HEAD_SHA"

# --- Detect Python project anywhere (monorepo-friendly) ---
HAS_PY=0
if find . -maxdepth 6 -name "pyproject.toml" -o -name "requirements.txt" -o -name "requirements-dev.txt" -o -name "poetry.lock" 2>/dev/null | rg -q .; then
  HAS_PY=1
fi

if [[ "$HAS_PY" -eq 1 ]]; then
  echo "== gate: python =="

  command -v python3 >/dev/null || fail "python3 not found"
  if [[ ! -x ".venv/bin/python" ]]; then
    fail "Python detected but .venv/bin/python missing at repo root. Run: $HOME/.codex/scripts/ensure_venv (do NOT delete .venv)."
  fi

  PY=".venv/bin/python"

  # Install tooling only if already declared by the repo; do not auto-install here.
  # Gate must stay deterministic and non-mutating.

  if "$PY" -c "import ruff" >/dev/null 2>&1; then
    "$PY" -m ruff format --check .
    "$PY" -m ruff check .
  else
    echo "INFO: ruff not installed in .venv; skipping ruff"
  fi

  if "$PY" -c "import mypy" >/dev/null 2>&1; then
    "$PY" -m mypy .
  else
    echo "INFO: mypy not installed in .venv; skipping mypy"
  fi

  if "$PY" -c "import pytest" >/dev/null 2>&1; then
    "$PY" -m pytest -q
  else
    fail "pytest not installed in .venv"
  fi
fi

# --- Node (repo root package.json only; keep it simple) ---
if [[ -f "package.json" ]]; then
  echo "== gate: node =="
  PM="npm"
  command -v pnpm >/dev/null && PM="pnpm"
  command -v yarn >/dev/null && PM="yarn"

  $PM -s run lint
  $PM -s run test || echo "INFO: test script failed/missing; define stable test script to enforce"
  $PM -s run build
fi

# --- Terraform ---
if ls *.tf >/dev/null 2>&1 || [[ -d "infra" ]] || [[ -d "terraform" ]]; then
  echo "== gate: terraform =="
  command -v terraform >/dev/null || fail "terraform not found"
  terraform fmt -check -recursive
  terraform validate
fi

ok