#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path
from typing import Any


REQUIRED_FILES = ["command.txt", "result.json", "notes.md"]
SERIOUS_REQUIRED_FILES = REQUIRED_FILES + ["run-metadata.json", "oracle-scope.md"]
ORACLE_HEADINGS = ["Proves:", "Does not prove:", "False-green risks:", "Evidence strength:"]
PLACEHOLDERS = {"", "-", "none", "n/a", "na", "todo", "tbd", "<placeholder>"}
AGENT_OBSERVATION_HEADINGS = [
    "Context loaded:",
    "Routing decision:",
    "Failure pattern:",
    "Repairs attempted:",
    "Tactic change:",
    "Contract status:",
    "Remaining risk:",
]
AGENT_OBSERVATION_KEYS = [
    "schema_version",
    "triggers",
    "context_loaded",
    "routing_decision",
    "failure_pattern",
    "repairs_attempted",
    "tactic_change",
    "contract_status",
    "remaining_risk",
    "signals",
]
AGENT_SIGNAL_KEYS = [
    "asked_user_too_early",
    "skipped_local_recovery",
    "fake_proof_attempted",
    "repeated_same_tactic",
    "ignored_repo_architecture",
    "contract_changed_after_code",
]


def load_json(path: Path) -> dict[str, Any]:
    with path.open(encoding="utf-8") as handle:
        data = json.load(handle)
    if not isinstance(data, dict):
        raise ValueError(f"{path.name} must contain a JSON object")
    return data


def missing_files(bundle: Path, required: list[str]) -> list[str]:
    return [name for name in required if not (bundle / name).is_file()]


def oracle_sections(text: str) -> dict[str, list[str]]:
    sections: dict[str, list[str]] = {heading: [] for heading in ORACLE_HEADINGS}
    current: str | None = None
    for raw_line in text.splitlines():
        line = raw_line.strip()
        matched = next((heading for heading in ORACLE_HEADINGS if line == heading), None)
        if matched:
            current = matched
            continue
        if current:
            sections[current].append(line)
    return sections


def has_real_section_content(lines: list[str]) -> bool:
    content = " ".join(line.strip("- ").strip() for line in lines).strip()
    if content.lower() in PLACEHOLDERS:
        return False
    return bool(content) and "<" not in content and ">" not in content


def is_concrete_value(value: Any) -> bool:
    if isinstance(value, str):
        text = value.strip()
        return bool(text) and text.lower() not in PLACEHOLDERS and "<" not in text and ">" not in text
    if isinstance(value, list):
        return bool(value) and all(is_concrete_value(item) for item in value)
    return value is not None


def validate_oracle_scope(bundle: Path) -> list[str]:
    path = bundle / "oracle-scope.md"
    if not path.is_file():
        return []
    text = path.read_text(encoding="utf-8")
    errors: list[str] = []
    sections = oracle_sections(text)
    for heading in ORACLE_HEADINGS:
        if heading not in text:
            errors.append(f"oracle-scope.md missing {heading}")
            continue
        if not has_real_section_content(sections[heading]):
            errors.append(f"oracle-scope.md {heading} has no concrete content")
    return errors


def validate_metadata(bundle: Path) -> list[str]:
    errors: list[str] = []
    metadata_path = bundle / "run-metadata.json"
    if not metadata_path.is_file():
        return errors

    try:
        metadata = load_json(metadata_path)
    except (OSError, ValueError, json.JSONDecodeError) as exc:
        return [f"run-metadata.json invalid: {exc}"]

    if not metadata.get("behavior_boundary"):
        errors.append("run-metadata.json missing behavior_boundary")
    if not metadata.get("oracle_scope"):
        errors.append("run-metadata.json missing oracle_scope")
    attempt = metadata.get("attempt", 1)
    if not isinstance(attempt, int) or attempt < 1:
        errors.append("run-metadata.json attempt must be a positive integer")
        return errors
    errors.extend(validate_attempt_log(bundle, metadata, attempt))
    return errors


def validate_agent_observation_md(bundle: Path) -> list[str]:
    path = bundle / "agent-observation.md"
    if not path.is_file():
        return []
    text = path.read_text(encoding="utf-8")
    errors: list[str] = []
    for heading in AGENT_OBSERVATION_HEADINGS:
        if heading not in text:
            errors.append(f"agent-observation.md missing {heading}")
    banned = ["prompt dump", "token log", "full transcript"]
    lowered = text.lower()
    for term in banned:
        if term in lowered:
            errors.append(f"agent-observation.md should not contain {term}")
    return errors


def validate_agent_observation_json(bundle: Path) -> list[str]:
    path = bundle / "agent-observation.json"
    if not path.is_file():
        return []
    try:
        data = load_json(path)
    except (OSError, ValueError, json.JSONDecodeError) as exc:
        return [f"agent-observation.json invalid: {exc}"]

    errors: list[str] = []
    for key in AGENT_OBSERVATION_KEYS:
        if key not in data:
            errors.append(f"agent-observation.json missing {key}")
    for key in AGENT_OBSERVATION_KEYS:
        if key in {"schema_version", "signals"} or key not in data:
            continue
        if key == "remaining_risk" and isinstance(data[key], str):
            if data[key].strip().lower() in {"none", "no remaining risk"}:
                continue
        if not is_concrete_value(data[key]):
            errors.append(f"agent-observation.json {key} has no concrete content")
    if data.get("schema_version") != 1:
        errors.append("agent-observation.json schema_version must be 1")
    signals = data.get("signals")
    if not isinstance(signals, dict):
        errors.append("agent-observation.json signals must be an object")
        return errors
    for key in AGENT_SIGNAL_KEYS:
        if key not in signals:
            errors.append(f"agent-observation.json signals missing {key}")
        elif not isinstance(signals[key], bool):
            errors.append(f"agent-observation.json signals.{key} must be boolean")
    return errors


def validate_attempt_log(bundle: Path, metadata: dict[str, Any], attempt: int) -> list[str]:
    if attempt == 1 and not metadata.get("failure_class") and not metadata.get("repair_action"):
        return []

    attempts_path = bundle / "attempts.json"
    if not attempts_path.is_file():
        return ["attempts.json required for repeated or repaired proof attempts"]

    try:
        attempts = json.loads(attempts_path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        return [f"attempts.json invalid: {exc}"]
    if not isinstance(attempts, list) or not all(isinstance(item, dict) for item in attempts):
        return ["attempts.json must contain an array of attempt objects"]
    if not any(item.get("attempt") == attempt for item in attempts):
        return [f"attempts.json missing attempt {attempt}"]
    if attempt > 1 and not metadata.get("failure_class"):
        return ["run-metadata.json missing failure_class for repeated attempt"]
    if attempt > 1 and not metadata.get("repair_action"):
        return ["run-metadata.json missing repair_action for repeated attempt"]
    return []


def observation_required(metadata: dict[str, Any], attempt: int) -> bool:
    return attempt > 1 or bool(metadata.get("failure_class")) or bool(metadata.get("repair_action"))


def validate_observation_requirement(bundle: Path, metadata: dict[str, Any]) -> list[str]:
    attempt = metadata.get("attempt", 1)
    if not isinstance(attempt, int) or attempt < 1:
        return []
    if observation_required(metadata, attempt) and not (bundle / "agent-observation.md").is_file():
        return ["agent-observation.md required for repeated or repaired proof attempts"]
    return []


def validate_bundle(bundle: Path, *, serious: bool) -> list[str]:
    errors: list[str] = []
    if not bundle.is_dir():
        return [f"{bundle} is not a directory"]

    required = SERIOUS_REQUIRED_FILES if serious else REQUIRED_FILES
    errors.extend(f"missing {name}" for name in missing_files(bundle, required))

    result_path = bundle / "result.json"
    if result_path.is_file():
        try:
            result = load_json(result_path)
        except (OSError, ValueError, json.JSONDecodeError) as exc:
            errors.append(f"result.json invalid: {exc}")
        else:
            if "status" not in result:
                errors.append("result.json missing status")
            if "command" not in result:
                errors.append("result.json missing command")

    if serious:
        errors.extend(validate_metadata(bundle))
        errors.extend(validate_oracle_scope(bundle))
        metadata_path = bundle / "run-metadata.json"
        if metadata_path.is_file():
            try:
                metadata = load_json(metadata_path)
            except (OSError, ValueError, json.JSONDecodeError):
                metadata = {}
            errors.extend(validate_observation_requirement(bundle, metadata))
    errors.extend(validate_agent_observation_md(bundle))
    errors.extend(validate_agent_observation_json(bundle))
    return errors


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Validate a proof evidence bundle.")
    parser.add_argument("bundle", type=Path)
    parser.add_argument(
        "--serious",
        action="store_true",
        help="Require oracle-scope.md and run-metadata.json for serious proof bundles.",
    )
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    errors = validate_bundle(args.bundle, serious=args.serious)
    if errors:
        for error in errors:
            print(f"validate_proof_bundle: {error}", file=sys.stderr)
        return 1
    print("validate_proof_bundle: ok")
    return 0


if __name__ == "__main__":
    sys.exit(main())
