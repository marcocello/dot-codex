#!/usr/bin/env bash
set -euo pipefail

ROOT="$(pwd)"

fail() {
  local msg="$1"
  echo "GATE: FAIL: $msg" >&2
  exit 1
}

pass() {
  echo "GATE: PASS"
}

# Deterministic single-line SHA (informational only)
if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  HEAD_SHA="$(git rev-parse --verify HEAD 2>/dev/null || echo "no-git")"
else
  HEAD_SHA="no-git"
fi

echo "== gate: repo=$ROOT sha=$HEAD_SHA =="

# Detect python anywhere (monorepo-ish)
HAS_PY=0
if find . -maxdepth 6 \
  \( -name "pyproject.toml" -o -name "requirements.txt" -o -name "requirements-dev.txt" -o -name "poetry.lock" \) \
  2>/dev/null | head -n 1 | grep -q .; then
  HAS_PY=1
fi

if [[ "$HAS_PY" -eq 1 ]]; then
  echo "== gate: python detected =="

  # Enforce your backend layout
  [[ -d "app" ]] || fail "Expected backend code under ./app (missing app/ directory)"

  # Catch common failure: pip installed packages into repo root (fastapi/, pytest/, etc.)
  if [[ -d "fastapi" || -d "pytest" ]]; then
    fail "Detected top-level package directories (e.g., fastapi/, pytest/). Dependencies must be installed inside .venv only."
  fi

  if [[ ! -x ".venv/bin/python" ]]; then
    fail "Python detected but .venv/bin/python missing at repo root. Run: $HOME/.codex/scripts/ensure_venv (do NOT delete .venv)."
  fi

  PY=".venv/bin/python"

  "$PY" -c "import ruff" >/dev/null 2>&1 || fail "ruff not installed in .venv. Run: $HOME/.codex/scripts/ensure_venv"
  "$PY" -m ruff format --check .
  "$PY" -m ruff check .

  "$PY" -c "import mypy" >/dev/null 2>&1 || fail "mypy not installed in .venv. Install with: .venv/bin/python -m pip install mypy"
  MYPY_TARGETS=()
  for target in app scripts tests lovejoy.py press.py; do
    if [[ -f "$target" ]]; then
      MYPY_TARGETS+=("$target")
      continue
    fi
    if [[ -d "$target" ]] && find "$target" -type f \( -name "*.py" -o -name "*.pyi" \) | head -n 1 | grep -q .; then
      MYPY_TARGETS+=("$target")
    fi
  done
  [[ "${#MYPY_TARGETS[@]}" -gt 0 ]] || fail "mypy target set is empty; expected python files under app/, scripts/, tests/, or top-level tools."
  "$PY" -m mypy "${MYPY_TARGETS[@]}"

  "$PY" -c "import pytest" >/dev/null 2>&1 || fail "pytest not installed in .venv"
  # Ignore embedded worktrees/snapshots that may contain unrelated repos and dependencies.
  "$PY" -m pytest -q \
    --ignore=worktrees \
    --ignore=archived_sessions \
    --ignore=.venv \
    --ignore=vendor_imports \
    --ignore=tmp

  # Run dependency audit only when python dependency manifests changed.
  if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    CHANGED_FILES="$(
      {
        git diff --name-only HEAD
        git ls-files --others --exclude-standard
      } | sort -u
    )"
  else
    CHANGED_FILES=""
  fi

  if echo "$CHANGED_FILES" | grep -Eq '^(app/requirements(-dev)?\.txt|requirements(-dev)?\.txt|poetry\.lock|uv\.lock)$'; then
    "$PY" -c "import pip_audit" >/dev/null 2>&1 || fail "pip-audit not installed in .venv. Install with: .venv/bin/python -m pip install pip-audit"
    echo "== gate: pip-audit =="
    # Audit current environment because manifest changes imply dependency risk changes.
    "$PY" -m pip_audit
  else
    echo "INFO: no python dependency manifest changes; skipping pip-audit"
  fi
fi

# --- Node (repo root package.json only; deterministic) ---
if [[ -f "package.json" ]]; then
  echo "== gate: node =="
  command -v node >/dev/null || fail "node not found but package.json exists"

  PM="npm"
  command -v pnpm >/dev/null && PM="pnpm"
  command -v yarn >/dev/null && PM="yarn"

  $PM -s run lint

  # Only run tests if the script exists; if it exists, failure is a gate failure.
  if node -e "const p=require('./package.json'); process.exit(p.scripts && p.scripts.test ? 0 : 1)"; then
    $PM -s run test
  else
    echo "INFO: no test script in package.json; skipping node tests"
  fi

  $PM -s run build
fi

# Terraform (simple)
if ls *.tf >/dev/null 2>&1 || [[ -d "infra" ]] || [[ -d "terraform" ]]; then
  echo "== gate: terraform detected =="
  command -v terraform >/dev/null || fail "terraform not found"
  terraform fmt -check -recursive
  terraform validate
fi

pass
