#!/usr/bin/env bash
set -euo pipefail

ROOT="$(pwd)"
ART_DIR="$ROOT/artifacts"
mkdir -p "$ART_DIR"

HEAD_SHA="$(git rev-parse HEAD 2>/dev/null || echo "no-git")"

fail() {
  local msg="$1"
  echo "GATE: FAIL: $msg" >&2
  python3 - <<PY
import json, os
p = {"head_sha": "$HEAD_SHA", "passed": False, "error": "$msg"}
os.makedirs("$ART_DIR", exist_ok=True)
with open("$ART_DIR/gate.json", "w", encoding="utf-8") as f:
  json.dump(p, f, indent=2)
PY
  exit 1
}

pass() {
  echo "GATE: PASS"
  python3 - <<PY
import json, os
p = {"head_sha": "$HEAD_SHA", "passed": True}
os.makedirs("$ART_DIR", exist_ok=True)
with open("$ART_DIR/gate.json", "w", encoding="utf-8") as f:
  json.dump(p, f, indent=2)
PY
}

echo "== gate: repo=$ROOT sha=$HEAD_SHA =="

# Detect python anywhere (monorepo-ish)
HAS_PY=0
if find . -maxdepth 6 \
  \( -name "pyproject.toml" -o -name "requirements.txt" -o -name "requirements-dev.txt" -o -name "poetry.lock" \) \
  2>/dev/null | head -n 1 | grep -q .; then
  HAS_PY=1
fi

if [[ "$HAS_PY" -eq 1 ]]; then
  echo "== gate: python detected =="

  if [[ ! -x ".venv/bin/python" ]]; then
    fail "Python detected but .venv/bin/python missing at repo root. Use: $HOME/.codex/scripts/ensure_venv (do NOT delete .venv)."
  fi

  PY=".venv/bin/python"

  if "$PY" -c "import ruff" >/dev/null 2>&1; then
    "$PY" -m ruff format --check .
    "$PY" -m ruff check .
  else
    echo "INFO: ruff not installed in .venv; skipping ruff"
  fi

  if "$PY" -c "import mypy" >/dev/null 2>&1; then
    "$PY" -m mypy .
  else
    echo "INFO: mypy not installed in .venv; skipping mypy"
  fi

  "$PY" -c "import pytest" >/dev/null 2>&1 || fail "pytest not installed in .venv"
  "$PY" -m pytest -q
fi

# --- Node (repo root package.json only; deterministic) ---
if [[ -f "package.json" ]]; then
  echo "== gate: node =="
  command -v node >/dev/null || fail "node not found but package.json exists"

  PM="npm"
  command -v pnpm >/dev/null && PM="pnpm"
  command -v yarn >/dev/null && PM="yarn"

  $PM -s run lint

  # Only run tests if the script exists; if it exists, failure is a gate failure.
  if node -e "const p=require('./package.json'); process.exit(p.scripts && p.scripts.test ? 0 : 1)"; then
    $PM -s run test
  else
    echo "INFO: no test script in package.json; skipping node tests"
  fi

  $PM -s run build
fi

# Terraform (simple)
if ls *.tf >/dev/null 2>&1 || [[ -d "infra" ]] || [[ -d "terraform" ]]; then
  echo "== gate: terraform detected =="
  command -v terraform >/dev/null || fail "terraform not found"
  terraform fmt -check -recursive
  terraform validate
fi

pass