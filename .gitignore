## From https://jasonstitt.com/gitignore-whitelisting-patterns

# 1. Ignore everything
*

# 2. But descend into directories
!/docs/
!/docs/**/

!/scripts/

!/skills/
!/skills/**/

!/tests/
!/tests/**/

# 3. Allow specific files and file extensions
!.gitignore
!*.md
!*.py
!*.toml
!*.ini
!*.yaml
!*.sh
!scripts/gate
!scripts/gate_config
!scripts/harness_review
!scripts/lint_harness
!scripts/proof_run_capture
!scripts/validate_feature_queue
!docs/harness/evolution/*.json
!docs/presentations/*.html

# 4. Block some directories and files
*.git
**/.venv/
skills/.system/
config.toml
