#!/usr/bin/env bash
set -euo pipefail

FEATURE_DIR=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --feature)
      FEATURE_DIR="$2"
      shift 2
      ;;
    *)
      shift
      ;;
  esac
done

if [[ -z "$FEATURE_DIR" ]]; then
  echo "Usage: acceptance --feature <dir>" >&2
  exit 2
fi

ROOT="$(pwd)"

# Deterministic single-line SHA
if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  HEAD_SHA="$(git rev-parse --verify HEAD 2>/dev/null || echo "no-git")"
else
  HEAD_SHA="no-git"
fi

echo "== acceptance: feature=$FEATURE_DIR sha=$HEAD_SHA =="

fail() {
  local msg="$1"
  echo "ACCEPTANCE: FAIL: $msg" >&2
  exit 1
}

# Must use project venv
if [[ ! -x ".venv/bin/python" ]]; then
  fail ".venv/bin/python missing. Run $HOME/.codex/scripts/ensure_venv"
fi

PY=".venv/bin/python"

"$PY" -c "import pytest" >/dev/null 2>&1 || fail "pytest not installed in .venv"

# Run only feature-scoped tests if directory exists
if [[ -d "$FEATURE_DIR/acceptance" ]]; then
  "$PY" -m pytest -q "$FEATURE_DIR/acceptance"
else
  echo "INFO: no acceptance directory found for feature; skipping."
fi

echo "ACCEPTANCE: PASS"