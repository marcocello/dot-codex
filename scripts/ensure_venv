#!/usr/bin/env bash
set -euo pipefail

ROOT="${1:-$(pwd)}"
cd "$ROOT"

VENV=".venv"
PY="$VENV/bin/python"
PIP="$VENV/bin/pip"

echo "== ensure_venv =="
echo "repo=$(pwd)"

# Enforce convention: requirements live under app/
# If you want to allow root requirements.txt, set ALLOW_ROOT_REQUIREMENTS=1
if [[ -f "requirements.txt" && "${ALLOW_ROOT_REQUIREMENTS:-0}" != "1" ]]; then
  echo "ERROR: found ./requirements.txt but this setup expects requirements under ./app/." >&2
  echo "Move it to ./app/requirements.txt (or set ALLOW_ROOT_REQUIREMENTS=1 to bypass)." >&2
  exit 2
fi

if [[ ! -d "app" ]]; then
  echo "ERROR: missing ./app directory. This setup expects backend code under ./app/." >&2
  exit 2
fi

# Create venv if missing
if [[ ! -x "$PY" ]]; then
  echo "Creating .venv..."
  python3 -m venv "$VENV"
fi

# Upgrade base tooling (best-effort in offline environments)
if ! "$PIP" install -U pip setuptools wheel >/dev/null; then
  echo "WARNING: could not update pip/setuptools/wheel (likely offline). Continuing with current versions." >&2
fi

first_existing() {
  for p in "$@"; do
    if [[ -f "$p" ]]; then
      echo "$p"
      return 0
    fi
  done
  return 1
}

echo "Detecting dependency source..."

# Preferred: app-level requirements
REQ_DEV_CANDIDATES=(
  "app/requirements-dev.txt"
  "app/requirements/dev.txt"
  "app/requirements/dev-requirements.txt"
)

REQ_CANDIDATES=(
  "app/requirements.txt"
  "app/requirements/base.txt"
  "app/requirements/prod.txt"
)

# Optional: root pyproject (only if you actually package the repo)
# If you don't package, keep this off.
if [[ -f "pyproject.toml" && "${ALLOW_ROOT_PYPROJECT_INSTALL:-0}" == "1" ]]; then
  echo "Found pyproject.toml (root) and ALLOW_ROOT_PYPROJECT_INSTALL=1. Installing editable package..."
  "$PIP" install -e .
else
  if REQ_DEV="$(first_existing "${REQ_DEV_CANDIDATES[@]}" || true)"; [[ -n "${REQ_DEV:-}" ]]; then
    echo "Found $REQ_DEV. Installing..."
    "$PIP" install -r "$REQ_DEV"
  elif REQ="$(first_existing "${REQ_CANDIDATES[@]}" || true)"; [[ -n "${REQ:-}" ]]; then
    echo "Found $REQ. Installing..."
    "$PIP" install -r "$REQ"
  else
    echo "No app/requirements*.txt found. Installing minimal tooling only."
  fi
fi

# Ensure baseline tools needed by gate
echo "Ensuring baseline tooling (pytest, ruff, mypy, pip-audit)..."
if ! "$PIP" install -U pytest ruff mypy pip-audit >/dev/null; then
  echo "WARNING: could not install baseline tooling (likely offline). Verifying existing environment." >&2
fi

echo "== ensure_venv: done =="
"$PY" -c "import sys; print('python', sys.version.split()[0])"
"$PY" - <<'PY'
from importlib.metadata import PackageNotFoundError, version
import importlib

required_modules = ("pytest", "mypy")
missing = [name for name in required_modules if importlib.util.find_spec(name) is None]

for name in required_modules:
    if name in missing:
        continue
    mod = importlib.import_module(name)
    mod_version = getattr(mod, "__version__", version(name))
    print(f"{name} {mod_version}")

try:
    print(f"ruff {version('ruff')}")
except PackageNotFoundError:
    missing.append("ruff")

try:
    print(f"pip-audit {version('pip-audit')}")
except PackageNotFoundError:
    print("WARNING: pip-audit not available; dependency audits will fail when manifests change.")

if missing:
    raise SystemExit(f"missing required tooling in .venv: {', '.join(missing)}")
PY
