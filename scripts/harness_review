#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Any


PLACEHOLDERS = {"", "-", "none", "n/a", "na", "todo", "tbd", "<placeholder>"}
MANIFEST_REQUIRED_KEYS = {
    "change",
    "component_level",
    "component",
    "before_evidence",
    "after_evidence",
    "evidence",
    "failure_pattern",
    "root_cause",
    "why_this_component",
    "targeted_fix",
    "expected_fix",
    "observability_signal",
    "predicted_fixes",
    "predicted_regressions",
    "regression_risk",
    "held_out_checks",
    "rollback_plan",
    "verification",
    "verdict_basis",
    "verdict",
}
FINAL_VERDICTS = {"accepted", "rejected", "rollback"}
RISK_SIGNALS = [
    "asked_user_too_early",
    "skipped_local_recovery",
    "fake_proof_attempted",
    "repeated_same_tactic",
    "ignored_repo_architecture",
    "contract_changed_after_code",
]


def observation_required(metadata: dict[str, Any]) -> bool:
    attempt = metadata.get("attempt", 1)
    return (
        isinstance(attempt, int)
        and attempt > 1
        or bool(metadata.get("failure_class"))
        or bool(metadata.get("repair_action"))
    )


def load_json(path: Path) -> dict[str, Any] | None:
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return None
    return data if isinstance(data, dict) else None


def has_real_value(value: Any) -> bool:
    if isinstance(value, str):
        text = value.strip()
        return bool(text) and text.lower() not in PLACEHOLDERS and "<" not in text and ">" not in text
    if isinstance(value, list):
        return bool(value) and all(has_real_value(item) for item in value)
    return value is not None


def proof_results(root: Path) -> list[tuple[Path, str]]:
    results: list[tuple[Path, str]] = []
    for result_path in sorted(root.glob("docs/features/*/proof/runs/*/result.json")):
        data = load_json(result_path) or {}
        status = str(data.get("status", "UNKNOWN"))
        results.append((result_path.parent.relative_to(root), status))
    return results


def manifest_results(root: Path) -> list[tuple[Path, str]]:
    manifests: list[tuple[Path, str]] = []
    base = root / "docs" / "harness" / "evolution" / "manifests"
    for manifest_path in sorted(base.glob("*.json")):
        data = load_json(manifest_path) or {}
        verdict = str(data.get("verdict", "unknown"))
        manifests.append((manifest_path.relative_to(root), verdict))
    return manifests


def manifest_validation_errors(path: Path, data: dict[str, Any]) -> list[str]:
    errors: list[str] = []
    missing = sorted(MANIFEST_REQUIRED_KEYS - set(data))
    errors.extend(f"missing {key}" for key in missing)

    for key in sorted(MANIFEST_REQUIRED_KEYS & set(data)):
        if key in {"after_evidence", "verification", "verdict_basis"}:
            continue
        if not has_real_value(data[key]):
            errors.append(f"{key} has no concrete content")

    verdict = str(data.get("verdict", "")).lower()
    if verdict in FINAL_VERDICTS:
        for key in ["after_evidence", "verification", "verdict_basis"]:
            if not has_real_value(data.get(key)):
                errors.append(f"{key} is required for final verdict {verdict}")
    elif verdict and verdict != "pending":
        errors.append(f"verdict must be pending, accepted, rejected, or rollback: {verdict}")

    for key in ["predicted_fixes", "predicted_regressions", "held_out_checks"]:
        if key in data and not isinstance(data[key], list):
            errors.append(f"{key} must be a list")
    return [f"{path.name}: {error}" for error in errors]


def all_manifest_errors(root: Path) -> list[tuple[Path, list[str]]]:
    errors: list[tuple[Path, list[str]]] = []
    base = root / "docs" / "harness" / "evolution" / "manifests"
    for manifest_path in sorted(base.glob("*.json")):
        data = load_json(manifest_path)
        if data is None:
            errors.append((manifest_path.relative_to(root), [f"{manifest_path.name}: invalid JSON object"]))
            continue
        manifest_errors = manifest_validation_errors(manifest_path, data)
        if manifest_errors:
            errors.append((manifest_path.relative_to(root), manifest_errors))
    return errors


def agent_observation_results(root: Path) -> tuple[list[Path], list[str]]:
    observations: list[Path] = []
    risk_lines: list[str] = []
    for json_path in sorted(root.glob("docs/features/*/proof/runs/*/agent-observation.json")):
        observations.append(json_path.parent.relative_to(root))
        data = load_json(json_path) or {}
        signals = data.get("signals", {})
        if not isinstance(signals, dict):
            continue
        active = [key for key in RISK_SIGNALS if signals.get(key) is True]
        if active:
            risk_lines.append(f"- `{json_path.parent.relative_to(root)}`: {', '.join(active)}")
    for md_path in sorted(root.glob("docs/features/*/proof/runs/*/agent-observation.md")):
        run_path = md_path.parent.relative_to(root)
        if run_path not in observations:
            observations.append(run_path)
    return sorted(set(observations)), risk_lines


def agent_observation_gaps(root: Path) -> list[Path]:
    gaps: list[Path] = []
    for metadata_path in sorted(root.glob("docs/features/*/proof/runs/*/run-metadata.json")):
        data = load_json(metadata_path) or {}
        run_path = metadata_path.parent
        if observation_required(data) and not (run_path / "agent-observation.md").is_file():
            gaps.append(run_path.relative_to(root))
    return gaps


def feature_dirs(root: Path) -> list[Path]:
    paths: set[Path] = set()
    for proof_path in root.glob("docs/features/*/PROOF.md"):
        paths.add(proof_path.parent.relative_to(root))

    status_path = root / "docs" / "features" / "status.json"
    status = load_json(status_path) or {}
    features = status.get("features", [])
    if isinstance(features, list):
        for item in features:
            if not isinstance(item, dict):
                continue
            feature_dir = item.get("feature_dir")
            if isinstance(feature_dir, str) and feature_dir:
                paths.add(Path(feature_dir))
    return sorted(paths)


def missing_run_evidence(root: Path) -> list[Path]:
    missing: list[Path] = []
    for feature_dir in feature_dirs(root):
        run_results = list((root / feature_dir / "proof" / "runs").glob("*/result.json"))
        if not run_results:
            missing.append(feature_dir)
    return missing


def build_report(root: Path) -> str:
    proofs = proof_results(root)
    manifests = manifest_results(root)
    manifest_errors = all_manifest_errors(root)
    observations, risk_lines = agent_observation_results(root)
    observation_gaps = agent_observation_gaps(root)
    pass_count = sum(1 for _, status in proofs if status.upper() == "PASS")
    fail_count = sum(1 for _, status in proofs if status.upper() == "FAIL")

    lines = [
        "# Harness Review",
        "",
        f"- Created: {datetime.now(timezone.utc).isoformat()}",
        f"- Proof bundles: {len(proofs)} total, {pass_count} PASS, {fail_count} FAIL",
        f"- Change manifests: {len(manifests)}",
        f"- Agent observations: {len(observations)}",
        "",
        "## Failed Proof Bundles",
    ]
    failed = [(path, status) for path, status in proofs if status.upper() != "PASS"]
    lines.extend(f"- `{path}`: {status}" for path, status in failed)
    if not failed:
        lines.append("- none")

    lines.extend(["", "## Missing Run Evidence"])
    missing_evidence = missing_run_evidence(root)
    lines.extend(f"- `{path}`" for path in missing_evidence)
    if not missing_evidence:
        lines.append("- none")

    lines.extend(["", "## Pending Change Manifests"])
    pending = [(path, verdict) for path, verdict in manifests if verdict == "pending"]
    lines.extend(f"- `{path}`: {verdict}" for path, verdict in pending)
    if not pending:
        lines.append("- none")

    lines.extend(["", "## Manifest Validation"])
    if manifest_errors:
        for path, errors in manifest_errors:
            lines.append(f"- `{path}`")
            lines.extend(f"  - {error}" for error in errors)
    else:
        lines.append("- none")

    lines.extend(["", "## Agent Risk Signals"])
    if risk_lines:
        lines.extend(risk_lines)
    else:
        lines.append("- none")

    lines.extend(["", "## Agent Observation Gaps"])
    if observation_gaps:
        lines.extend(
            f"- `{path}`: repeated or repaired proof attempt without agent-observation.md"
            for path in observation_gaps
        )
    else:
        lines.append("- none")
    return "\n".join(lines) + "\n"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Summarize proof bundles and harness manifests.")
    parser.add_argument("--root", type=Path, default=Path.cwd())
    parser.add_argument("--write", action="store_true")
    parser.add_argument("--check", action="store_true", help="validate manifests without writing a report")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    if args.check:
        errors = all_manifest_errors(args.root)
        if errors:
            for path, path_errors in errors:
                for error in path_errors:
                    print(f"harness_review: {path}: {error}", file=sys.stderr)
            return 1
        print("harness_review: ok")
        return 0
    report = build_report(args.root)
    if args.write:
        target = args.root / "docs" / "harness" / "evolution" / "latest-review.md"
        target.parent.mkdir(parents=True, exist_ok=True)
        target.write_text(report, encoding="utf-8")
        print(f"harness_review: wrote {target}")
    else:
        print(report, end="")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
